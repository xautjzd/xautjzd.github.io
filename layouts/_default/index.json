{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- if and (ne .Type "page") (ne .Layout "search") -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "summary" (.Summary | plainify) "content" (.Plain | truncate 300) "permalink" .Permalink "date" .Date "tags" .Params.tags) -}}
  {{- end -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
